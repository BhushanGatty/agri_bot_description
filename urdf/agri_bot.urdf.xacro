<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="agri_bot">

  <xacro:property name="chassis_l" value="0.8"/>
  <xacro:property name="chassis_w" value="0.5"/>
  <xacro:property name="chassis_h" value="0.2"/>
  <xacro:property name="chassis_m" value="15.0"/>

  <xacro:property name="wheel_r" value="0.15"/>
  <xacro:property name="wheel_w" value="0.1"/>
  <xacro:property name="wheel_m" value="2.0"/>

  <xacro:property name="arm_base_r" value="0.06"/>
  <xacro:property name="arm_base_h" value="0.12"/>
  <xacro:property name="link1_h" value="0.25"/>
  <xacro:property name="link2_h" value="0.20"/>
  <xacro:property name="link3_h" value="0.05"/>

  <xacro:macro name="box_inertia" params="m l w h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(1/12)*m*(w*w + h*h)}" ixy="0.0" ixz="0.0" 
               iyy="${(1/12)*m*(l*l + h*h)}" iyz="0.0" 
               izz="${(1/12)*m*(l*l + w*w)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(1/12)*m*(3*r*r + h*h)}" ixy="0.0" ixz="0.0" 
               iyy="${(1/12)*m*(3*r*r + h*h)}" iyz="0.0" 
               izz="${(1/2)*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_r}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="${chassis_l} ${chassis_w} ${chassis_h}"/></geometry>
      <material name="chassis_mat"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="${chassis_l} ${chassis_w} ${chassis_h}"/></geometry>
    </collision>
    <xacro:box_inertia m="${chassis_m}" l="${chassis_l}" w="${chassis_w}" h="${chassis_h}"/>
  </link>

  <xacro:macro name="wheel" params="prefix x_reflect y_reflect">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
        <material name="wheel_mat"><color rgba="0.05 0.05 0.05 1.0"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_m}" r="${wheel_r}" h="${wheel_w}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="${x_reflect*(chassis_l/3)} ${y_reflect*(chassis_w/2 + wheel_w/2)} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="front_left"  x_reflect="1"  y_reflect="1"/>
  <xacro:wheel prefix="front_right" x_reflect="1"  y_reflect="-1"/>
  <xacro:wheel prefix="rear_left"   x_reflect="-1" y_reflect="1"/>
  <xacro:wheel prefix="rear_right"  x_reflect="-1" y_reflect="-1"/>

  <link name="arm_base_link">
    <visual>
      <geometry><cylinder radius="0.06" length="0.12"/></geometry>
      <material name="arm_mat"><color rgba="0.6 0.6 0.6 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.06" length="0.12"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="1.5" r="0.06" h="0.12"/>
  </link>

  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="${chassis_l/3} 0 ${chassis_h/2 + 0.06}" rpy="0 0 0"/>
  </joint>

  <link name="link_1">
    <visual>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 0.15"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 0.15"/></geometry>
    </collision>
    <xacro:box_inertia m="1.0" l="0.06" w="0.06" h="0.15"/>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="arm_base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.30"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.30"/></geometry>
    </collision>
    <xacro:box_inertia m="1.2" l="0.05" w="0.05" h="0.30"/>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.15" rpy="0 0.4 0"/> <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="15.0" velocity="1.0"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.24"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.24"/></geometry>
    </collision>
    <xacro:box_inertia m="0.8" l="0.04" w="0.04" h="0.24"/>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.30" rpy="0 -0.8 0"/> <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link_4">
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.16"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.16"/></geometry>
    </collision>
    <xacro:box_inertia m="0.5" l="0.035" w="0.035" h="0.16"/>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0.24" rpy="0 0.4 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="8.0" velocity="1.2"/>
  </joint>

  <link name="link_5">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.06"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.06"/></geometry>
    </collision>
    <xacro:box_inertia m="0.3" l="0.03" w="0.03" h="0.06"/>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5.0" velocity="1.5"/>
  </joint>

  <link name="left_finger">
    <visual><geometry><box size="0.01 0.02 0.05"/></geometry></visual>
    <collision><geometry><box size="0.01 0.02 0.05"/></geometry></collision>
    <xacro:box_inertia m="0.05" l="0.01" w="0.02" h="0.05"/>
  </link>

  <joint name="left_finger_joint" type="prismatic">
    <parent link="link_5"/> <child link="left_finger"/>
    <origin xyz="0 0.02 0.06" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.02" upper="0.0" effort="5.0" velocity="0.1"/>
  </joint>

  <link name="right_finger">
    <visual><geometry><box size="0.01 0.02 0.05"/></geometry></visual>
    <collision><geometry><box size="0.01 0.02 0.05"/></geometry></collision>
    <xacro:box_inertia m="0.05" l="0.01" w="0.02" h="0.05"/>
  </link>

  <joint name="right_finger_joint" type="prismatic">
    <parent link="link_5"/> <child link="right_finger"/>
    <origin xyz="0 -0.02 0.06" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.02" upper="0.0" effort="5.0" velocity="0.1"/>
  </joint>

  <ros2_control name="IgnitionSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    
    <joint name="front_left_wheel_joint"><command_interface name="velocity"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="front_right_wheel_joint"><command_interface name="velocity"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="rear_left_wheel_joint"><command_interface name="velocity"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="rear_right_wheel_joint"><command_interface name="velocity"/><state_interface name="position"/><state_interface name="velocity"/></joint>

    <joint name="joint_1"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint_2"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint_3"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint_4"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint_5"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint> <joint name="left_finger_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="right_finger_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find agri_bot_description)/config/agri_bot_controllers.yaml</parameters>
    </plugin>
  </gazebo>
  
 <link name="camera_mast">
    <visual>
      <geometry><cylinder radius="0.015" length="0.8"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.015" length="0.8"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="camera_mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_mast"/>
    <origin xyz="-0.2 0.0 0.5" rpy="0.0 0.0 0.0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.05 0.15 0.05"/></geometry>
      <material name="red"><color rgba="0.8 0.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.05 0.15 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="camera_mast"/>
    <child link="camera_link"/>
    <origin xyz="0.0 0.0 0.4" rpy="0.0 0.26 0.0"/>
  </joint>

  <link name="camera_link_optical"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_link_optical"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <gazebo reference="camera_link">
    <sensor type="rgbd_camera" name="rgbd_camera">
      <update_rate>15.0</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <topic>camera</topic>
      <camera>
        <horizontal_fov>1.4</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>10.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  
</robot>
